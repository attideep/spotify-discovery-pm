# Demo mode: works without Spotify keys (verified track IDs only)
MOCK_MODE=false
ALLOW_DEMO_MODE=true

# Optional: Supabase Postgres — bridge analytics + distributed rate limits
DATABASE_URL=

# API abuse protection (requests/minute per IP for /api/bridge and /api/ask)
RATE_LIMIT_PER_MINUTE=30

# LLM — enables Claude bridge planner + richer Ask answers
ANTHROPIC_API_KEY=

# Optional: Gemini embeddings (falls back to hash embeddings)
GEMINI_API_KEY=

# Spotify Bridge Sessions (required for live personalized bridges + save playlist)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=https://spotify-discovery-pm.vercel.app/mvp/callback

# Sign cookies in production (generate: python -c "import secrets; print(secrets.token_hex(32))")
SESSION_SECRET=change-me-in-production

# Public URLs
API_BASE_URL=https://spotify-discovery-pm.vercel.app
WEB_BASE_URL=https://spotify-discovery-pm.vercel.app
