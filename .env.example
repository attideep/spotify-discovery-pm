# Demo mode works without keys using cached corpus + hash embeddings
MOCK_MODE=true

# LLM (required for live analysis)
ANTHROPIC_API_KEY=

# Optional: Gemini embeddings (falls back to hash embeddings)
GEMINI_API_KEY=

# Optional: Supabase Postgres + pgvector
DATABASE_URL=

# Spotify Bridge Sessions MVP
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8000/mvp/callback

# Public URLs (set after deploy)
API_BASE_URL=http://localhost:8000
WEB_BASE_URL=http://localhost:4321
